root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cs,shader,cginc,hlsl,compute}]
indent_size = 4

[*.{json,asmdef,asmref,uxml,uss}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# Unity YAML はインデント差で diff が壊れるので触らない
[*.{unity,prefab,asset,mat,anim,controller,asmdef.meta,meta}]
indent_size = unset
trim_trailing_whitespace = false
insert_final_newline = unset
