# =============================================================================
# Unity 生成物
# =============================================================================
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Unity AssetStoreTools プラグイン（入れてもコミットしない）
/[Aa]ssets/AssetStoreTools*
/[Aa]ssets/AssetStoreTools*.meta

# Test Runner / Coverage 結果（実行ごとに変わる）
[Tt]est[Rr]esults/
[Cc]odeCoverage/
*.coverage

# Profiler / Frame Debugger / Recorder の出力
*.data
*.captures/
*.raw
[Pp]rofiler[Cc]aptures/

# TextMesh Pro 動的フォールバック（Editor 実行で勝手に文字が足される）
/[Aa]ssets/TextMesh Pro/Resources/Fonts & Materials/*Fallback*.asset
/[Aa]ssets/TextMesh Pro/Resources/Fonts & Materials/*Fallback*.asset.meta

# Per-platform Burst AOT 設定（CommonBurstAotSettings.json はトラック維持。
# Editor/Player/Standalone* など Editor が勝手に書き換えるものだけ無視）
/[Pp]roject[Ss]ettings/BurstAotSettings_*.json
/[Pp]roject[Ss]ettings/BurstAotSettings_*.gen.cs

# Unity Cloud Build / Cloud Diagnostics 生成
[Cc]loud[Bb]uild/
.unity-cloud-build/

# Package Cache（Unity 2020+ で Library 外に出ることがある）
[Pp]ackage[Cc]ache/

# Shader cache（Library 外に漏れる場合の保険）
ShaderCache/

# =============================================================================
# IDE / エディタ生成物
# =============================================================================
# Visual Studio cache directory
.vs/
# JetBrains Rider
.idea/
# Visual Studio Code（共有したい場合は個別に !/.vscode/settings.json 等で除外）
.vscode/

# Cursor / その他 AI IDE
.cursor/
.cursorrules.local

# Gradle cache directory
.gradle/

# JetBrains Rider が散らかすパッケージレベルファイル
*.DotSettings.user
*.csproj.DotSettings

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# =============================================================================
# クラッシュ / ログ
# =============================================================================
# Unity3D generated file on crash reports
sysinfo.txt
# 任意のログファイル（MJPEG 受信ログ等のローカルダンプ）
*.log

# =============================================================================
# Builds
# =============================================================================
*.apk
*.aab
*.idsig
*.unitypackage
*.app
*.exe
*.x86_64
# IL2CPP / Burst バックアップ
*.il2cpp.tmp
*BurstDebugInformation_DoNotShip*/
*BackUpThisFolder_ButDontShipItWithYourGame*/
*_BackUpThisFolder_ButDontShipItWithYourGame/
*_BurstDebugInformation_DoNotShip/

# Android Studio / Gradle ビルド
**/build/
**/.gradle/
local.properties

# Crashlytics generated file
crashlytics-build.properties

# =============================================================================
# Addressables
# =============================================================================
# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# =============================================================================
# OS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
Icon
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.stackdump

# =============================================================================
# Env / secrets
# =============================================================================
.env
.env.local
/[Aa]ssets/[Ss]treamingAssets/secrets.json
/[Aa]ssets/[Ss]treamingAssets/secrets.*.json

# =============================================================================
# Claude Code / harness
# =============================================================================
# Claude Code local overrides
.claude/settings.local.json

# Claude Code agent worktrees（ローカルでのみ存在する一時的な並列作業ツリー。
# git worktree 配下なので素直に commit すると submodule 扱いされてしまう）
.claude/worktrees/

# Claude Code runtime lock / state ファイル（ScheduleWakeup / 各種スケジューラが
# 動作中に作る一時ファイル。チームで共有する意味は無いので gitignore する）
.claude/*.lock
.claude/state/
.claude/cache/

# MCP per-project placeholder（実体は ~/.claude.json で管理されるため不要）
/.mcp.json

# web compositor のキャプチャ/録画（PC ローカル成果物・コミットしない）
tools/web-compositor/captures/
tools/web-compositor/recordings/
tools/web-compositor/prompts.json
tools/web-compositor/show.json
tools/web-compositor/masks/

# ビルド成果物（BuildVariants が出力）
Builds/
